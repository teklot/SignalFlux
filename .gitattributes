# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.cs text diff=csharp
*.csproj text
*.slnx text
*.props text
*.targets text
*.md text
*.json text
*.yml text
*.yaml text
*.ps1 text
*.sh text

# Binary
*.png binary
*.jpg binary
*.ico binary
*.exe binary
*.dll binary

# NuGet
*.nupkg binary
